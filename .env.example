# NeuroCausal RAG v5.0 - Environment Configuration
# Kopyala: cp .env.example .env
# Duzenleme: .env dosyasini ac ve degerleri guncelle
#
# Yazar: Ertugrul Akben

# =============================================================================
# OPENAI API
# =============================================================================
OPENAI_API_KEY=sk-your-api-key-here

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_PORT=8501
API_PORT=8000

# Database backends (true/false)
# false = Local NetworkX/FAISS (varsayilan)
# true = Neo4j/Milvus (docker-compose gerekli)
USE_NEO4J=false
USE_MILVUS=false

# =============================================================================
# API CONFIGURATION
# =============================================================================
# API Keys (virgul ile ayirmali, bos = auth kapatik)
NEUROCAUSAL_API_KEYS=my-secret-key-1,my-secret-key-2

# Debug mode (hata detaylari)
DEBUG=false

# =============================================================================
# NEO4J CONFIGURATION
# =============================================================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=neurocausal123
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# =============================================================================
# MILVUS CONFIGURATION
# =============================================================================
MILVUS_PORT=19530
MILVUS_GRPC_PORT=9091

# MinIO (Milvus storage backend)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# OPTIONAL: ADMIN UI
# =============================================================================
# Attu (Milvus GUI) - docker-compose --profile admin up
ATTU_PORT=3000
